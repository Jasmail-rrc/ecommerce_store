<h1><%= @product.name %></h1>

<p>
  <strong>Category:</strong>
  <%= @product.category.name %>
</p>

<p><%= @product.description %></p>

<p>
  <strong>Price:</strong>
  <%= number_to_currency(@product.price) %>
</p>

<p>
  <strong>Available stock:</strong>
  <%= @product.stock_quantity %>
</p>

<%= link_to "Back to Products", products_path %>